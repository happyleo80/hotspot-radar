{
  "manifest_version": 3,
  "name": "五大平台热点雷达采集助手",
  "version": "0.1.0",
  "description": "用户主动采集当前页面可见热点内容，并确认后上传热点雷达后台。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://tophub.today/*",
    "https://weibo.com/*",
    "https://www.douyin.com/*",
    "https://www.xiaohongshu.com/*",
    "https://www.zhihu.com/*",
    "https://www.bilibili.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "采集当前热点页",
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://weibo.com/*",
        "https://tophub.today/*",
        "https://www.douyin.com/*",
        "https://www.xiaohongshu.com/*",
        "https://www.zhihu.com/*",
        "https://www.bilibili.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
