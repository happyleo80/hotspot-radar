DATABASE_URL=postgresql+psycopg2://hotspot:hotspot@postgres:5432/hotspot_radar
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Feishu OAuth login. Set AUTH_REQUIRED=true in production.
AUTH_REQUIRED=false
AUTH_SESSION_SECRET=replace-with-a-long-random-string
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8000/api/auth/feishu/callback

# Optional authorized third-party APIs.
TIANAPI_KEY=
ALAPI_KEY=
TOPHUB_API_KEY=

# Optional OpenAI-compatible model API.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
