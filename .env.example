DATABASE_URL=postgresql+psycopg2://hotspot:hotspot@postgres:5432/hotspot_radar
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Feishu OAuth login. Set AUTH_REQUIRED=true in production.
AUTH_REQUIRED=false
AUTH_SESSION_SECRET=replace-with-a-long-random-string
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8000/api/auth/feishu/callback

# Optional authorized third-party APIs.
TIANAPI_KEY=
ALAPI_KEY=
TOPHUB_API_KEY=

# Recommended OpenAI-compatible LLM API config. DeepSeek is the default provider.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Optional OpenAI-compatible fallback.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Backward-compatible DeepSeek keys. Prefer LLM_* for new deployments.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding model config. DeepSeek is the brain; Embedding is the memory index.
EMBEDDING_PROVIDER=mock
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=1024
EMBEDDING_ENABLED=false
AI_TOPIC_COST_POINTS=10
ADMIN_OPEN_IDS=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
DIGITALING_DAILY_IMPORT_ENABLED=true
DIGITALING_IMPORT_LIMIT=100
HOTSPOT_REFRESH_INTERVAL_MINUTES=30
